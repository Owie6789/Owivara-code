# ========================================
# OWIVARA - DEVELOPMENT
# Environment Variables Template
# ========================================
# Copy this file to .env in each app directory and fill in your values.
# NEVER commit .env to version control!

# ─── InsForge Backend ───────────────────
# Get these from your InsForge project dashboard
VITE_INSFORGE_URL=https://your-project.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key_here

# Backend (Bot Framework / Orchestrator)
INSFORGE_URL=https://your-project.insforge.app
INSFORGE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres:your_password@your-project.database.insforge.app:5432/insforge?sslmode=require

# ─── Bot Orchestrator ───────────────────
# Webhook endpoint (InsForge Edge Function URL)
BOT_WEBHOOK_URL=https://your-edge-function-url/bot-webhook
BOT_WEBHOOK_SECRET=generate_a_random_secret_here

# Bot server port
PORT=3000

# ─── AI Providers (BYOK - User brings their own) ───
# These are for the app's AI features
# User API keys are stored encrypted in InsForge DB

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# ─── pxxl.click Deployment ────────────
PXXL_API_KEY=your_pxxl_api_key_here
